---
import * as howDoesItWork from '@/content/faq/how-does-it-work.md';
import * as isItReal from '@/content/faq/is-it-real.md';
import * as whatDoesItMean from '@/content/faq/what-does-it-mean.md';
import * as whatIsTokiPona from '@/content/faq/what-is-toki-pona.md';

import Layout from '@/layouts/Layout.astro';

const faq = [
	whatIsTokiPona,
	isItReal,
	howDoesItWork,
	whatDoesItMean,
];

// fetch all questions, omit the ones we already have
// append any that were missing to the end
const allEntries = import.meta.glob('@/content/faq/*.md', { eager: true });
const manualImports = new Set(faq.map((item) => item.file));

const headings = faq.flatMap((item) =>
	item.getHeadings().filter((heading) => heading.depth <= 2),
);
---

<style>
	.right-toc {
		position: sticky;
		top: 1rem;
		line-height: 1.7;
	}
	.small-toc {
		display: none;
		margin-bottom: 0.5rem;
	}
	@media only screen and (max-width: 1200px) {
		.right-toc {
			display: none !important;
		}
		.small-toc {
			display: block;
		}
	}
	ol li {
		& a {
			color: var(--foreground);
			text-decoration: none;
			&:hover {
				text-decoration: underline;
			}
		}
		&::marker {
			content: counter(list-item) '  ';
			color: var(--foreground-muted);
			width: 2ch;
			text-align: right;
			padding-right: 1ch;
			display: block;
		}
	}
	.kasi {
		display: flex;
		list-style-type: none;
		row-gap: 1em;
		flex-wrap: wrap;
		justify-content: space-evenly;
		max-width: 40em;
		margin: 0 auto;
	}
	.kasi li {
		margin: 0;
		aspect-ratio: 1 / 1;
		max-width: 10em;
		position: relative;
		display: grid;
		grid-template-rows: max-content 1fr;
		box-shadow: rgba(195, 187, 24, 0.25) 0px 30px 60px -12px inset, rgba(239, 242, 205, 0.3) 0px 18px 36px -18px inset;How does Toki Pona work with only 130 words?
	}
	.kasi a{
		text-align: center;
		background-color: rgb(22, 33, 22);
		display: grid;
		color: lightcyan;
		text-decoration: none;
		padding: 1em 0.25em;
	}
	.kasi span{
		align-self: center;
	}
	.kasi a::after{
		content: "";
		position: absolute;
		top: 0;
		bottom: 0;
		right:0;
		left: 0;
	}
    .faq {
        display: grid;
        grid-template-columns:  auto auto;
        column-gap: 0.5em;
        justify-content: space-evenly;
        
        .plant-card {
            background-color: var(--card-background);
            align-self: center;
            border-radius: var(--rounding-large);
            max-width: 200px;


            dl{
                font-family: sans;
                font-size: 0.7em;
                padding: 1em;
            }
            dd {
                display: inline;

                margin: 0;
                padding: 0;
                width: 100%;
                img {
                    display: 
                    block;
                    max-width: 150px;
                    margin: 0 auto;
                }
                

            }
            dt{
                display: inline;
                margin: 0 1em 0 0;
                font-weight: 800;
            }

        }
        .entry{
            max-width: 30em;
        }
        
    }
    @media (max-width: 35em ){
        .faq{
            grid-template-columns: 1fr;
            justify-items: center;

        }

    }


</style>

<Layout
	title={'The Basics | Toki Pona'}
	description={'This is a test page.'}
>
	<section style='grid-area: right;' class='right-toc'>
		<nav>
			<ol>
				{
					headings.map((item) => (
						<li>
							<a href={`#${item.slug}`}>{item.text}</a>
						</li>
					))
				}
			</ol>
		</nav>
	</section>
	<section style='grid-area: left;'>
		<h1>The Basics</h1>

        

		<details open class='small-toc'>
			<summary>Table of Contents</summary>
			<ol>
				{
					headings.map((item) => (
						<li>
							<a href={`#${item.slug}`}>{item.text}</a>
						</li>
					))
				}
			</ol>
		</details>
<div class="faq">
    
            {faq.map((item) =>
            <div class="entry">
                <item.Content />
            </div>
            <div class="plant-card">
                <dl>
                    <dt>Specimen</dt>
                    <dd>{item.frontmatter.species}
                    <img src={`/sitelen/kasi/${item.frontmatter.image}`}>
                    </dd>

                    <dt>Notes</dt>
                    <dd>{item.frontmatter.species_notes}</dd>
                </dl>
            </div>
            )}
</div>
	</section>
</Layout>
