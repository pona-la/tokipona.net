---
import * as howDoesItWork from '@/content/faq/how-does-it-work.md';
import * as isItReal from '@/content/faq/is-it-real.md';
import * as whatDoesItMean from '@/content/faq/what-does-it-mean.md';
import * as whatIsTokiPona from '@/content/faq/what-is-toki-pona.md';
import * as whatSoundLike from '@/content/faq/what-sounds-like.md';
import { slugify } from 'astro/zod';
import Layout from '@/layouts/Layout.astro';

const faq = [
	whatIsTokiPona,
	isItReal,
	howDoesItWork,
	whatDoesItMean,
	whatSoundLike,
];

// fetch all questions, omit the ones we already have
// append any that were missing to the end
const allEntries = import.meta.glob('@/content/faq/*.md', { eager: true });
const manualImports = new Set(faq.map((item) => item.file));

const headings = faq.flatMap((item) =>
	item.getHeadings().filter((heading) => heading.depth <= 2),
);
---

<style>
	.right-toc {
		position: sticky;
		top: 1rem;
		line-height: 1.7;
	}
	.small-toc {
		display: none;
		margin-bottom: 0.5rem;
	}
	@media only screen and (max-width: 1200px) {
		.right-toc {
			display: none !important;
		}
		.small-toc {
			display: block;
		}
	}
	ol li {
		& a {
			color: var(--foreground);
			text-decoration: none;
			&:hover {
				text-decoration: underline;
			}
		}
		&::marker {
			content: counter(list-item) '  ';
			color: var(--foreground-muted);
			width: 2ch;
			text-align: right;
			padding-right: 1ch;
			display: block;
		}
	}
	.main-content {
		max-width: 35em;
		margin: 0 auto;
	}
	.space-maker {
		width: 6rem;
		height: 1rem;
		float: left;
	}
	.plant {
		width: 5rem;
		z-index: 2;
		position: absolute;
		display: block;
		white-space: normal;
		margin-top: -2rem;
		padding: 0;
		float: left;
		border: none;
		background: none;

		summary::before {
			content: none;
		}

		img {
			max-width: 100%;
			border-radius: 50%;
			border: 0.5em solid var(--card-border);
			float: left;
			background-color: var(--card-background);
		}
	}
	.faq :global(h2) {
		&::after {
			z-index: 1;
		}
	}

	.garden {
		width: 100%;
		max-width: 50em;
		margin: 0 auto;
		display: flex;
		flex-wrap: nowrap;
		position: relative;
		top: 0.4em;

		img {
			max-width: 100%;
			user-drag: none;
			user-select: none;
		}
	}

	.entry-wrap :global(h2) {
		padding-left: 5.5rem;
		margin-inline: 0;
		text-align: left;
	}
    .entry-wrap{
        margin-block: 2.5em;
    }
	.summary {
		width: 70vw;
		max-width: 25em;

		border-color: var(--scene-background);
		border-style: solid;
		border-end-end-radius: var(--rounding-large);
		border-start-end-radius: var(--rounding-large);
		border-end-start-radius: var(--rounding-large);
		border-width: 0.2em 0.4em 0.4em 0.2em;
		background-color: var(--background);
		z-index: 4;
		padding: 1em;
		background-color: rgb(22, 33, 22);
		color: lightcyan;
	}

	.summary {
		position: absolute;
		left: inherit;
		right: inherit;
		top: inherit;
		bottom: inherit;
		margin-top: 1em;
		margin-left: 4em;
		list-style-type: none;
	}

	.intro {
		background-color: rgb(22, 33, 22);
		color: lightcyan;
		border-radius: var(--rounding-small);
		padding: 1em;
		grid-column: 1 / 3;
	}
	.summary {
		z-index: 4;
	}

	@media (max-width: 35em) {
	}
</style>

<Layout title={'The Basics | Toki Pona'} description={'This is a test page.'}>
	<section style='grid-area: right;' class='right-toc'>
		<nav>
			<ol>
				{
					headings.map((item) => (
												<li>
							<a href={`#${item.slug}`}>{item.text}</a>
						</li>

					))
				}
			</ol>
		</nav>
	</section>
	<section style='grid-area: left;'>
		<h1>The Basics</h1>

		<details open class='small-toc'>
			<summary>Table of Contents</summary>
			<ol>
				{
					headings.map((item) => (
						<li>
							<a href={`#${item.slug}`}>{item.text}</a>
						</li>
					))
				}
			</ol>
		</details>
		<div class='main-content'>
			<div class='garden'>
				{
					faq.map((item) => (
						<div>
							<img
								src={`/sitelen/kasi/${item.frontmatter.image}`}
							/>
						</div>
					))
				}
			</div>

			<div class='faq'>
				<div class='intro'>
					<p>What this language's deal?</p>

					<p>
						Is it even a language? Here, we provide a basic profile
						of what the language is.
					</p>
				</div>

				{
					faq.map((item) => (
						<article class='entry-wrap'>
							<h2>{item.frontmatter.title}</h2>
							<div class='entry'>
								<details class='plant'>
									<summary class='plant'>
										<img
											alt='Show summary'
											src={`/sitelen/kasi/${item.frontmatter.image}`}
										/>
									</summary>
									<div
										class='summary'
										id={item.frontmatter.species.replaceAll(
											' ',
											'-',
										)}
									>
										{item.frontmatter.simple}
									</div>
								</details>
								<div class='entry-content'>
									<div class='space-maker' />
									<item.Content />
								</div>
							</div>
						</article>
					))
				}
			</div>
		</div>
	</section>
    <script is:inline>
	function lightDismiss() {
        console.log("mu");

		document.querySelectorAll('details.plant').forEach((details) => {
            details.addEventListener('toggle', (event) => {
                // Only run when the state changes to open
                if (details.open) {
                    // Define the outside click handler function
                    const closeOnOutsideClick = (clickEvent) => {
                        if (!details.contains(clickEvent.target)) {
                            details.removeAttribute('open');
                            // Self-cleanup: remove this listener immediately
                            document.removeEventListener(
                                'click',
                                closeOnOutsideClick,
                            );
                        }
                    };

                    // Delay listener attachment slightly to prevent immediate triggering from the summary click
                    setTimeout(() => {
                        document.addEventListener(
                            'click',
                            closeOnOutsideClick,
                        );
                    }, 0);
                }
            });
        });
	}
document.addEventListener("DOMContentLoaded", lightDismiss);
</script>

</Layout>
