---
import Background from '../components/Background.astro';
import Layout from '../layouts/Layout.astro';
---

<Layout>
	<container>
		<Background />
		<pitch>
			<h1>Toki Pona</h1>
			<mockup-window>
				<window-content>
					<iframe
						width='1280'
						height='720'
						src='https://www.youtube-nocookie.com/embed/U3GQePblz4M'
						title='What is the easiest language?'
						allow='accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share'
						referrerpolicy='strict-origin-when-cross-origin'
						allowfullscreen></iframe>
				</window-content>
			</mockup-window>
		</pitch>
		<description>
			<h2>
				Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut labore et dolore
				magna aliqua.
			</h2>
		</description>
	</container>
</Layout>

<style>
	container {
		display: grid;
		position: absolute;
		width: 100%;
		min-height: calc(100% - 4rem);
		grid-template-columns: 3fr 2fr;
		grid-template-rows: 3fr 1fr;
		grid-column-gap: 0px;
		grid-row-gap: 0px;

		div {
			width: 100%;
			height: 100%;
		}

		pitch {
			grid-area: 1 / 1 / 2 / 2;
			display: flex;
			flex-direction: column;
			justify-content: center;
			align-items: center;
			text-align: center;
			padding: 3rem;
			mockup-window {
				width: 100%;
				background-color: var(--background);
				border: 3px solid var(--text);
				border-radius: 1rem;
				position: relative;
				display: flex;
				flex-direction: column;
				overflow: hidden;
				overflow-x: auto;
				padding-top: 1.25rem;
				&:before {
					content: '';
					margin-bottom: 1rem;
					display: block;
					aspect-ratio: 1 / 1;
					height: 0.75rem;
					flex-shrink: 0;
					align-self: flex-start;
					border-radius: calc(infinity * 1px);
					opacity: 0.3;
					box-shadow:
						1.4em 0,
						2.8em 0,
						4.2em 0;
				}
				[dir='rtl'] &:before {
					align-self: flex-end;
				}

				window-content {
					border-top: 3px solid var(--text);
					iframe {
						width: 100%;
						height: auto;
						aspect-ratio: 16 / 9;
					}
				}
			}
		}
		description {
			grid-area: 1 / 2 / 2 / 3;
			display: flex;
			flex-direction: column;
			justify-content: center;
			align-items: center;
			text-align: center;
			padding: 3rem;
		}
	}
</style>
