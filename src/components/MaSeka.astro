---
import IframeSrcdoc from '@/components/IframeSrcdoc.astro';

interface Props {
	name: string;
	maSekaId: string;
	youtubeId: string;
}

const { name, maSekaId, youtubeId } = Astro.props;

// `thumbnailUrl` li tan ilo pali Aso. ilo pi jan lukin la ona li awen. tan ni la o sona e ni:
// nasin sitelen lon li ken kama ante li tan e pakala. mi sona ala e mute pi tenpo ni. taso ni li ken.
// ni li lon tenpo mute la mi o kepeken ala e nasin ni. nasin ante tu wan li ken:
// - o alasa e sitelen lon ilo Jutu (`https://i.ytimg.com/vi_webp/${youtubeId}/mqdefault.webp`).
//   nasin ni la ike tu li lon: kulupu Kukol li kama sona e ni: sina alasa e sitelen; ma pi Jutu ala
//   (ma Sonko, ma Lusi) la ona li pali ala
// - o alasa e sitelen lon ilo pi jan lukin. o lukin e ante ni pi ilo Kitu tawa sona: 0e554ad7.
// - o kama jo e sitelen o pana e ona.
//
//
// `thumbnailUrl` is generated by Astro. for the user it doesn't change. that's why be aware of this:
// the real URL might change. i don't know how often that happens. but it ken happen.
// if it happens too often, we should not do it this way. there are 3 other ways:
// - use youtube to get the thumbnail (`https://i.ytimg.com/vi_webp/${youtubeId}/mqdefault.webp`).
//   there are 2 problems with this way: google can track you by this request. in the countries where
//   youtube is blocked, this won't work
// - get the thumbnail on the user device. checkout this commits for implementation: 0e554ad7.
// - store the thumbnails on this site.

let thumbnailUrl;
try {
	const res = await fetch(`https://seka.pona.la/api/v1/videos/${maSekaId}`);
	if (!res.ok) throw new Error('ilo monsi li pana e pakala');

	const data = await res.json();

	thumbnailUrl = `https://seka.pona.la${data.thumbnailPath}`;
} catch (e) {
	console.warn(`mi alasa e sitelen sinpin pi sitelen tawa ni: ${maSekaId}. pakala li lon:`, e);

	thumbnailUrl = `https://i.ytimg.com/vi_webp/${youtubeId}/mqdefault.webp`;
}
---

<style>
	.container {
		box-sizing: content-box;
		position: relative;
		width: 100%;
		padding-bottom: 56.25%;
		overflow: hidden;
		max-width: 1280px;
		margin: 0 auto;
		border: 3px solid var(--card-border);
		border-radius: var(--rounding-small);
	}

	.container * {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		border: 0;
	}
</style>

<div class='container'>
	<IframeSrcdoc
		title={name}
		frameborder='0'
		allow='accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share'
		allowfullscreen
		referrerpolicy='strict-origin-when-cross-origin'
	>
		<style is:inline>
			html,
			body {
				height: 100%;
				padding: 0;
				margin: 0;
			}
			a {
				text-decoration: none;
				color: inherit;
			}
			.thumbnail {
				position: absolute;
				z-index: 0;
				width: 100%;
				top: 0;
				bottom: 0;
			}
			.title {
				position: absolute;
				z-index: 2;
				top: 0;
				left: 0;
				right: 0;
				height: 1em;
				padding: 1em;
				overflow: hidden;
				white-space: nowrap;
				text-overflow: ellipsis;

				font-family: sans-serif;
				font-size: 1.2rem;
				font-weight: bold;
				background: linear-gradient(#000d, #0008, #0000);
				color: white;
			}
			.play {
				position: absolute;
				z-index: 1;
				top: 0;
				bottom: 0;
				left: 0;
				right: 0;
			}
			.playbutton {
				position: absolute;
				left: 50%;
				top: 50%;
				transform: translateX(-50%) translateY(-50%);

				color: white;
				font-size: 2rem;
				text-shadow: 0 0 0.5em black;
			}
		</style>
		<img
			class='thumbnail'

			src={thumbnailUrl}
		/>
		<a
			class='title'
			href={`https://www.youtube.com/watch?v=${youtubeId}`}
			target='_blank'>{name}</a
		>
		<a class='play' href={`https://seka.pona.la/videos/embed/${maSekaId}?autoplay=1`}>
			<span class='playbutton'>▶</span>
		</a>
		<script is:inline>
		</script>
	</IframeSrcdoc>
</div>
