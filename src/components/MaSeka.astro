---
import IframeSrcdoc from '@/components/IframeSrcdoc.astro';

interface Props {
	name: string;
	maSekaId: string;
	youtubeId: string;
}

const { name, maSekaId, youtubeId } = Astro.props;
---

<style>
	.container {
		box-sizing: content-box;
		position: relative;
		width: 100%;
		padding-bottom: 56.25%;
		overflow: hidden;
		max-width: 1280px;
		margin: 0 auto;
		border: 3px solid var(--card-border);
		border-radius: var(--rounding-small);
	}

	.container * {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		border: 0;
	}
</style>

<div class='container'>
	<IframeSrcdoc
		title={name}
		frameborder='0'
		allow='accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share'
		allowfullscreen
		referrerpolicy='strict-origin-when-cross-origin'
	>
		<style is:inline>
			html,
			body {
				height: 100%;
				padding: 0;
				margin: 0;
			}
			a {
				text-decoration: none;
				color: inherit;
			}
			.thumbnail {
				position: absolute;
				z-index: 0;
				width: 100%;
				top: 0;
				bottom: 0;
			}
			.title {
				position: absolute;
				z-index: 2;
				top: 0;
				left: 0;
				right: 0;
				height: 1em;
				padding: 1em;
				overflow: hidden;
				white-space: nowrap;
				text-overflow: ellipsis;

				font-family: sans-serif;
				font-size: 1.2rem;
				font-weight: bold;
				background: linear-gradient(#000d, #0008, #0000);
				color: white;
			}
			.play {
				position: absolute;
				z-index: 1;
				top: 0;
				bottom: 0;
				left: 0;
				right: 0;
			}
			.playbutton {
				position: absolute;
				left: 50%;
				top: 50%;
				transform: translateX(-50%) translateY(-50%);

				color: white;
				font-size: 2rem;
				text-shadow: 0 0 0.5em black;
			}
		</style>
		<img
			class='thumbnail'
			data-masakaid={maSekaId}
			data-youtubeid={youtubeId}
			data-loaded="false"
		/>
		<a
			class='title'
			href={`https://www.youtube.com/watch?v=${youtubeId}`}
			target='_blank'>{name}</a
		>
		<a class='play' href={`https://seka.pona.la/videos/embed/${maSekaId}?autoplay=1`}>
			<span class='playbutton'>▶</span>
		</a>
		<script is:inline>
			async function loadThumbnail(img) {
					const maSekaId = img.dataset.masakaid;
					const youtubeId = img.dataset.youtubeid;				try {

					const res = await fetch(`https://seka.pona.la/api/videos/${maSekaId}`);
					if (!res.ok) throw new Error('API failed');

					const data = await res.json();

					const url = data.thumbnailPath;

					img.src = url;
					img.dataset.loaded = "true";
				} catch (e) {
					console.warn(`mi alasa e sitelen sinpin pi sitelen tawa ni: ${maSekaId}. pakala li lon`, e);

					img.src = `https://i.ytimg.com/vi_webp/${youtubeId}/mqdefault.webp`;
				}
			}

			document.addEventListener('DOMContentLoaded', () => {
				const images = document.querySelectorAll('img.thumbnail');

				images.forEach((img) => {
					loadThumbnail(img);
				});
			});
		</script>
	</IframeSrcdoc>
</div>
