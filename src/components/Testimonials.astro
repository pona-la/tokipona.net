---
import { render } from "astro:content";
import { getCollection } from "astro:content";

const testimonials = await getCollection("testimonials");
const selectedTestimonials = testimonials.sort((a, b) => a.data.author.localeCompare(b.data.author));
---

<style>
	figure {
		margin: 0;
		margin-block: 0;
		margin-inline: 0;
		display: grid;
		grid-template-rows: max-content max-content;
		align-items: center;
		break-inside: avoid;
		padding: 1.5em;
		

	}
	figure:nth-of-type(3n+1){
		background-color: var(--card-background);
	}
	figure:nth-of-type(3n+2){
		background-color: var(--border);
	}

	figure:nth-of-type(4n-1){
		background-color: var(--scene-background);
	}

	blockquote {
		position: relative;
		margin: 0;
		padding-block: 0rem;
		
	}
	figcaption {
		margin-top: 0.5rem;
		color: var(--color-secondary);
		text-align: right;
	}
	.testimonials{
		column-width: 20em;
		column-gap: 0;
	}
</style>
		<div class="testimonials">

{selectedTestimonials.map(async (testimonial) => {
	const { Content } = await render(testimonial);
	return (
			<figure>
				<blockquote>
					<Content />
				</blockquote>
				<figcaption>
					— <cite>{testimonial.data.author}</cite>
				</figcaption>
			</figure>
	);
})}
		</div>

<script>
	function scrambleTestimonials() {
  const container = document.querySelector('div.testimonials');
  if (!container) return;

  const figures = [...container.querySelectorAll('figure')];

  // Fisher-Yates shuffle
  for (let i = figures.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [figures[i], figures[j]] = [figures[j], figures[i]];
  }

  // Re-append in shuffled order
  figures.forEach(fig => container.appendChild(fig));
}

scrambleTestimonials();
	document.addEventListener('DOMContentLoaded', scrambleTestimonials);
</script>
