---
interface Props {
	instance: string;
	id: string;
}
const { instance, id } = Astro.props;
---

<style>
	.container {
		box-sizing: border-box;
		position: relative;
		width: 100%;
		padding-bottom: 56.25%;
		overflow: hidden;
		max-width: 1280px;
		margin: 0 auto;
		border: 3px solid var(--card-border);
		border-radius: var(--rounding-small);
	}

	.container iframe {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		border: 0;
	}
</style>

<div class='container'>
	<iframe
		src={`https://${instance}/videos/embed/${id}`}
		title='YouTube video player'
		frameborder='0'
		allow='accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share'
		referrerpolicy='strict-origin-when-cross-origin'
		allowfullscreen></iframe>
</div>
