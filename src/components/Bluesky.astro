---
const styles = `
.text-slate-500 {
	color: var(--txt-muted);
}
.border-slate-300 {
	border: 3px solid color-mix(in srgb, var(--orange), transparent 70%);
	border-radius: 10px;
}
:has(> article) {
	padding: 0;
}
section > :first-child {
	margin-top: 0;
}
section > * {
	margin-bottom: 0.5rem !important;
	&:not(:has(article)) {
		padding: 0.75rem !important;
	}
	& > article {
		padding: 0.75rem !important;
	}
}
a img {
	display: none
}
`;
---

<script
	type='module'
	src='https://cdn.jsdelivr.net/npm/bsky-embed/dist/bsky-embed.es.js'
	async></script>
<bsky-embed limit='2' username='tokipona.net' custom-styles={styles}>
</bsky-embed>
