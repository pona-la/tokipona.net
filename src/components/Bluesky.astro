---
const styles = `
* {
	font-family: "Andika", sans-serif;
}
.text-slate-500 {
	color: var(--foreground-muted);
}
section > *,
section > * > * {
	border:none !important;
}
.border-slate-300 {
	border: 3px solid color-mix(in oklch, var(--card-border), transparent 50%);
	border-radius: var(--rounding-small);
}
:has(> article) {
	padding: 0;
}
section > :first-child {
	margin-top: 0;
}
section > * {
	margin-bottom: 0.5rem !important;
	&:not(:has(article)) {
		padding: 0.5rem 1rem !important;
	}
	& > article {
		padding: 0.5rem 1rem !important;
	}
}
a img {
	display: none
}
a p {
	overflow: hidden;
	display: -webkit-box;
	-webkit-box-orient: vertical;
	-webkit-line-clamp: 2;
}
.flex.gap-2 {
	gap: 0.75rem;
}
.flex.gap-2 > :first-child {
	width: 3rem;
	height: 3rem;
}
`;
---

<script
	type='module'
	src='https://cdn.jsdelivr.net/npm/bsky-embed/dist/bsky-embed.es.js'
	async></script>
<bsky-embed limit='1' username='tokipona.net' custom-styles={styles}>
</bsky-embed>
