---
interface Props {
	url: string;
	img: string;
}
const { url, img } = Astro.props;
---

<style>
	.card {
		padding: 5px 15px;
		display: grid;
		grid-template-columns: 60px 1fr;
		grid-gap: 15px;
		align-items: center;
		border-radius: 1rem;
		transition: background-color 150ms;
	}
	.card:hover {
		background-color: var(--yellow);
	}
	a:hover .title {
		text-decoration: underline dotted;
	}
	img {
		width: 100%;
		border-radius: 15px;
		display: block;
	}
	a {
		font-weight: inherit;
		text-decoration: inherit;
		color: inherit;
	}
	a:active,
	a:hover {
		color: unset !important;
	}
	.desc {
		text-align: left;
	}
</style>

<a class='card' href={url}>
	<div class='sp'>{img && <img src={img} />}</div>
	<div class='desc'><slot /></div>
</a>
