---
import Layout from '@/layouts/Layout.astro';
interface Props {
	title: string;
	description: string;
    array: Array<{

    }>;
    faq_title: string;
}

const { title, description, array, faq_title} = Astro.props;

---

<style>
	.right-toc {
		position: sticky;
		top: 1rem;
		line-height: 1.7;
	}
	.small-toc {
		display: none;
		margin-bottom: 0.5rem;
        max-width: 30em;
        margin-inline: auto;
	}
	@media only screen and (max-width: 1200px) {
		.right-toc {
			display: none !important;
		}
		.small-toc {
			display: block;
		}
	}
	ol li {
		& a {
			color: var(--foreground);
			text-decoration: none;
			&:hover {
				text-decoration: underline;
			}
		}
		&::marker {
			content: counter(list-item) '  ';
			color: var(--foreground-muted);
			width: 2ch;
			text-align: right;
			padding-right: 1ch;
			display: block;
		}
	}
	.main-content {
		max-width: 35em;
		margin: 0 auto;
	}
	.space-maker {
		width: 6rem;
		height: 1rem;
		float: left;
	}
	.plant {
		width: 5rem;
		z-index: 2;
		position: absolute;
		display: block;
		white-space: normal;
		margin-top: -2rem;
		padding: 0;
		float: left;
		border: none;
		background: none;

		summary::before {
			content: none;
		}

		img {
			max-width: 100%;
			border-radius: 50%;
			border: 0.5em solid var(--card-border);
			float: left;
			background-color: var(--faq-child, var(--card-background));
		}
	}
	.faq :global(h2) {
		&::after {
			z-index: 1;
		}
	}


	.entry-wrap :global(h2) {
		padding-left: 5.5rem;
		margin-inline: 0;
		text-align: left;
	}
    .entry-wrap{
        margin-block: 2.5em;
    }
	.summary {
		width: 70vw;
		max-width: 25em;

		border-color: var(--scene-background);
		border-style: solid;
		border-end-end-radius: var(--rounding-large);
		border-start-end-radius: var(--rounding-large);
		border-end-start-radius: var(--rounding-large);
		border-width: 0.2em 0.4em 0.4em 0.2em;
		background-color: var(--background);
		z-index: 4;
		padding: 1em;
		background-color: rgb(22, 33, 22);
		color: lightcyan;
	}

	.summary {
		position: absolute;
		left: inherit;
		right: inherit;
		top: inherit;
		bottom: inherit;
		margin-top: 1em;
		margin-left: 4em;
		list-style-type: none;
	}

	
	.summary {
		z-index: 4;
	}

	@media (max-width: 35em) {
	}
</style>

<Layout title={title} description={description}>
	<section style='grid-area: right;' class='right-toc'>
		<nav>
			<ol>
				{
					array.map((item) => (
						<li>
							<a href={`#${item.id}`}>{item.data.title}</a>
						</li>
					))
				}
			</ol>
		</nav>
	</section>
	<section style='grid-area: left;'>
		<h1>{faq_title}</h1>

		<details open class='small-toc'>
			<summary>Table of Contents</summary>
			<ol>
				{
					array.map((item) => (
						<li>
							<a href={`#${item.id}`}>{item.data.title}</a>
						</li>
					))
				}
			</ol>
		</details>
		<div class='main-content'>
                                			<slot />


				{
					array.map(async(item) => (
						<article class='entry-wrap'>
							<h2 id={item.id}>
								{item.data.title}
							</h2>
							<div class='entry'>
								<details class='plant'>
									<summary class='plant'>
										<img
											alt='Show summary'
											src={`/sitelen/kasi/${item.data.image}`}
										/>
									</summary>
									<div
										class='summary'
										id={`icon${item.id}`}
									>
										{item.data.simple}
									</div>
								</details>
								<div set:html={await (item.rendered).html} class='entry-content'>
									<div class='space-maker' />
								</div>
							</div>
						</article>
					)
				)
				}
			</div>
		</div>
	</section>
    <script is:inline>
	function lightDismiss() {
        console.log("mu");

		document.querySelectorAll('details.plant').forEach((details) => {
            details.addEventListener('toggle', (event) => {
                // Only run when the state changes to open
                if (details.open) {
                    // Define the outside click handler function
                    const closeOnOutsideClick = (clickEvent) => {
                        if (!details.contains(clickEvent.target)) {
                            details.removeAttribute('open');
                            // Self-cleanup: remove this listener immediately
                            document.removeEventListener(
                                'click',
                                closeOnOutsideClick,
                            );
                        }
                    };

                    // Delay listener attachment slightly to prevent immediate triggering from the summary click
                    setTimeout(() => {
                        document.addEventListener(
                            'click',
                            closeOnOutsideClick,
                        );
                    }, 0);
                }
            });
        });
	}
document.addEventListener("DOMContentLoaded", lightDismiss);
</script>

</Layout>
